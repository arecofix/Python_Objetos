{
  "name": "arecofix",
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "dev": "rm -rf .angular && ng serve",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "npm run routes:update && npm run build && node scripts/remove-preloads.mjs",
    "generate-sitemap": "node scripts/sync-seo.mjs",
    "routes:update": "node scripts/sync-seo.mjs",
    "electron:dev": "ng build --configuration development --base-href ./ && electron .",
    "electron:build": "ng build --configuration production --base-href ./ && electron-builder build --windows",
    "firebase:build": "npm run routes:update && npm run build && node scripts/remove-preloads.mjs",
    "firebase:deploy": "npm run firebase:build && firebase deploy --only hosting",
    "firebase:serve": "firebase serve --only hosting",
    "tauri": "tauri"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "gh-pages": "^6.3.0",
    "trim-newlines": "^3.0.1",
    "uglify-js": "^3.19.3",
    "ajv": "^8.17.2",
    "minimatch": "^10.2.2"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-server": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/ssr": "^21.2.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@ionic/angular": "^8.7.17",
    "@mlc-ai/web-llm": "^0.2.80",
    "@supabase/supabase-js": "^2.49.1",
    "@types/express": "^5.0.0",
    "angularx-qrcode": "^21.0.4",
    "cally": "^0.9.2",
    "chart.js": "^4.4.8",
    "express": "^4.21.2",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "ng2-charts": "^8.0.0",
    "ngx-mask": "^21.0.1",
    "ngx-skeleton-loader": "^12.0.0",
    "posthog-js": "^1.352.0",
    "rxjs": "7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.1",
    "@capacitor/cli": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@tauri-apps/api": "^2.3.0",
    "@tauri-apps/cli": "^2.3.1",
    "@types/jasmine": "~5.1.5",
    "@types/node": "^22.13.5",
    "angular-cli-ghpages": "^3.0.2",
    "autoprefixer": "^10.4.24",
    "daisyui": "^5.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "url": "^0.11.4",
    "wrangler": "^4.70.0"
  },
  "build": {
    "appId": "com.arecofix.desktop",
    "productName": "Arecofix",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/arecofix/browser/**/*",
      "electron/main.js"
    ],
    "win": {
      "icon": "dist/arecofix/browser/assets/img/brands/logo/Logo.ico",
      "target": [
        "portable",
        "nsis"
      ]
    }
  }
}
