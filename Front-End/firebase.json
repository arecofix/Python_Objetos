            }
          ]
        },
        {
          "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    }
  ]
}
