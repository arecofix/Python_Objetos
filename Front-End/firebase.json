{
  "hosting": [
    {
      "target": "arecofix-default",
      "public": "dist/arecofix/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "index.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            },
            {
              "key": "Permissions-Policy",
              "value": "attribution-reporting=(), run-ad-auction=(), join-ad-interest-group=(), browsing-topics=()"
            }
          ]
        },
        {
          "source": "sitemap.xml",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "areco-fix",
      "public": "dist/arecofix/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
