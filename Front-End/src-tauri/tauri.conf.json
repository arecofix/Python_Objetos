{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arecofix-Local-Engine",
  "version": "0.1.0",
  "identifier": "com.arecofix.app",
  "build": {
    "frontendDist": "../dist/arecofix/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arecofix",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/arecofix-backend"
    ]
  }
}
